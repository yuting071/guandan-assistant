<?xml version="1.0" encoding="utf-8"?>
<!--
    掼蛋实时助手 AndroidManifest模板
    buildozer会自动使用此模板生成最终的AndroidManifest.xml
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="{{ package.name }}"
    android:versionCode="{{ android.versionCode }}"
    android:versionName="{{ android.version }}">

    <!-- 最小SDK版本 -->
    <uses-sdk android:minSdkVersion="{{ android.minapi }}"
        android:targetSdkVersion="{{ android.api }}" />

    <!-- 支持的CPU架构 -->
    {% for arch in android.archs %}
    <uses-library android:name="android.hardware.telephony" android:required="False" />
    {% endfor %}

    <!-- ==================== 权限声明 ==================== -->
    
    <!-- 悬浮窗权限 - 核心权限 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    
    <!-- 前台服务权限 - 用于截屏服务 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    
    <!-- 截屏权限 -->
    <uses-permission android:name="android.permission.CAPTURE_VIDEO_OUTPUT" />
    <uses-permission android:name="android.permission.CAPTURE_SECURE_VIDEO_OUTPUT" />
    
    <!-- 网络权限（可选，用于后续功能扩展） -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- 震动权限 -->
    <uses-permission android:name="android.permission.VIBRATE" />
    
    <!-- 唤醒锁（防止息屏） -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- ==================== 应用特性 ==================== -->
    <uses-feature android:name="android.hardware.screen.portrait" android:required="True" />
    
    <application
        android:name="{{ pkg_name }}.Main"
        android:label="{{ title }}"
        android:icon="@drawable/icon"
        android:theme="@android:style/Theme.NoTitleBar.Fullscreen"
        android:allowBackup="True"
        android:hardwareAccelerated="True"
        android:largeHeap="True">

        <!-- 主Activity -->
        <activity
            android:name="org.kivy.android.PythonActivity"
            android:label="{{ title }}"
            android:configChanges="keyboard|keyboardHidden|screenSize|orientation"
            android:screenOrientation="portrait"
            android:exported="true">
            
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ==================== 截屏服务 ==================== -->
        <service
            android:name=".ScreenCaptureService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <!-- ==================== 悬浮窗服务 ==================== -->
        <service
            android:name=".FloatWindowService"
            android:enabled="true"
            android:exported="false" />

    </application>

</manifest>
